# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/bot_hunter?retryWrites=true&w=majority

# Database Name (optional, defaults to bot_hunter)
DATABASE_NAME=bot_hunter

# JWT Secret Key (change this to a secure random string in production)
SECRET_KEY=your-secret-key-change-in-production

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

